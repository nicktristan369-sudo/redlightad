<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- App Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SMS Bridge"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Agency SMS Management"
            android:textSize="14sp"
            android:textColor="#888888"
            android:layout_marginBottom="24dp" />

        <!-- Status Card -->
        <LinearLayout
            android:id="@+id/statusCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#B71C1C"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <ImageView
                android:id="@+id/statusIcon"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@android:drawable/presence_offline"
                android:layout_gravity="center_vertical" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="16dp"
                android:layout_gravity="center_vertical">

                <TextView
                    android:id="@+id/statusText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Not Connected"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF" />

                <TextView
                    android:id="@+id/statusSubtext"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Enter server details below"
                    android:textSize="12sp"
                    android:textColor="#EEEEEE" />

            </LinearLayout>
        </LinearLayout>

        <!-- Config Card -->
        <LinearLayout
            android:id="@+id/configCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1E1E1E"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Server Configuration"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Server URL"
                android:textSize="12sp"
                android:textColor="#888888"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/serverUrlInput"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="#2A2A2A"
                android:paddingHorizontal="12dp"
                android:textColor="#FFFFFF"
                android:textColorHint="#666666"
                android:hint="https://redlightad.com"
                android:inputType="textUri"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Phone ID (from admin panel)"
                android:textSize="12sp"
                android:textColor="#888888"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/phoneIdInput"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="#2A2A2A"
                android:paddingHorizontal="12dp"
                android:textColor="#FFFFFF"
                android:textColorHint="#666666"
                android:hint="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
                android:inputType="text"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="API Key (optional)"
                android:textSize="12sp"
                android:textColor="#888888"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/apiKeyInput"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="#2A2A2A"
                android:paddingHorizontal="12dp"
                android:textColor="#FFFFFF"
                android:textColorHint="#666666"
                android:hint="API Key"
                android:inputType="textPassword"
                android:layout_marginBottom="16dp" />

            <Button
                android:id="@+id/connectButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Connect"
                android:textStyle="bold"
                android:backgroundTint="#DC2626" />

            <Button
                android:id="@+id/disconnectButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Disconnect"
                android:textStyle="bold"
                android:backgroundTint="#666666"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Service Toggle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#1E1E1E"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Background Service"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Keep running to receive SMS"
                    android:textSize="12sp"
                    android:textColor="#888888" />

            </LinearLayout>

            <Switch
                android:id="@+id/serviceToggle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical" />

        </LinearLayout>

        <!-- Permissions Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1E1E1E"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Permissions"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/permissionStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Checking..."
                android:textSize="14sp"
                android:textColor="#888888"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/permissionButton"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="Grant Permissions"
                android:textSize="12sp"
                android:backgroundTint="#333333"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/batteryButton"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="Disable Battery Optimization"
                android:textSize="12sp"
                android:backgroundTint="#333333" />

        </LinearLayout>

        <!-- Recent Messages Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1E1E1E"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📨 Recent Messages"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/recentMessages"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No messages yet"
                android:textSize="13sp"
                android:textColor="#AAAAAA"
                android:lineSpacingExtra="4dp" />

            <Button
                android:id="@+id/viewMessagesButton"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="Open SMS Inbox"
                android:textSize="12sp"
                android:backgroundTint="#333333"
                android:layout_marginTop="12dp" />

        </LinearLayout>

        <!-- Info -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="This app bridges SMS messages to your Agency Management System. Keep the app running in the background for 24/7 operation."
            android:textSize="12sp"
            android:textColor="#666666"
            android:textAlignment="center"
            android:layout_marginTop="8dp" />

    </LinearLayout>
</ScrollView>
